# Example mock / test-only env (do not use real keys).
# Use for local test runs with a dedicated test Chroma dir and optional Azure.
# Copy to .env.test and run: CHROMA_PERSIST_DIR=./chroma_test pytest tests/

# Isolated Chroma (set in conftest or here)
CHROMA_PERSIST_DIR=./chroma_test

# Azure (required when LLM_PROVIDER=azure). Use real values for integration tests.
LLM_PROVIDER=azure
# AZURE_OPENAI_API_KEY=...
# AZURE_OPENAI_ENDPOINT=https://your-resource.cognitiveservices.azure.com/
# AZURE_OPENAI_API_VERSION=2025-01-01-preview
# AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4.1-mini
# AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-small

# To simulate auth failure in tests, use monkeypatch in test_azure.py / test_edge_cases.py
# (do not put invalid keys in .env).
